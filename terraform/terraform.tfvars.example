region           = "us-west-2"
ecs_cluster_name = "osc-staging"
vpc_id           = "<vpc-id>"
subnet_ids       = ["<private-subnet-2a>", "<private-subnet-2b>"]
security_group_ids = ["<ecs-tasks-sg-id>"]
assign_public_ip = false
runtime_mode     = "up" # up | down

# Single RabbitMQ EC2 (MVP — one broker is sufficient)
ec2_instance_ids         = ["<rabbitmq-ec2-instance-id>"]
manage_ec2_runtime_state = true

# Safety guardrail: prevents accidental destroy of ECS services/task defs/log groups
protect_core_services = true

# --------------------
# ECS Services
# NOTE: service keys must match the actual ECS service names in the cluster
# --------------------
services = {
  # API Gateway — named osc-api-blue (blue/green deployment)
  "osc-api-blue" = {
    task_def_template_path = "${path.module}/../task-defs/api-gateway.json.tmpl"
    task_def_vars = {
      cpu                                     = "512"
      memory                                  = "1024"
      execution_role_arn                      = "<execution-role-arn>"
      task_role_arn                           = "<task-role-arn>"
      image                                   = "<ecr-image-uri>"
      submission_listener_service_role        = "<role-name>"
      db_port                                 = "5432"
      pgssl_ca_path                           = "/usr/local/share/ca-certificates/aws-rds-combined.crt"
      admin1_roles                            = "admin"
      db_ssl_servername                       = "<rds-hostname>"
      pgsslmode                               = "require"
      db_name                                 = "<db-name>"
      jwt_expires_in                          = "10m"
      admin2_roles                            = "admin"
      cors_origins                            = "<comma-separated-origins>"
      db_host                                 = "<rds-hostname>"
      db_ssl_reject_unauthorized              = "true"
      admin1_email                            = "<admin1-email>"
      admin1_username                         = "<admin1-username>"
      submission_listener_username            = "<listener-username>"
      db_ssl                                  = "true"
      admin2_email                            = "<admin2-email>"
      rabbitmq_port                           = "5672"
      admin2_username                         = "<admin2-username>"
      node_env                                = "production"
      rabbitmq_host                           = "<rabbitmq-nlb-dns>"
      ghw_url                                 = "http://osc-get-history-worker:8002"
      admin1_password_secret_arn              = "<secret-arn>"
      admin2_password_secret_arn              = "<secret-arn>"
      db_password_secret_arn                  = "<secret-arn>"
      db_user_secret_arn                      = "<secret-arn>"
      jwt_secret_arn                          = "<secret-arn>"
      rabbitmq_pass_secret_arn                = "<secret-arn>"
      rabbitmq_user_secret_arn                = "<secret-arn>"
      submission_listener_api_key_secret_arn  = "<secret-arn>"
      log_group                               = "/ecs/osc-api-blue"
      aws_region                              = "us-west-2"
    }
    desired_count = 1
  }

  # Adapter — replaces fabric-bridge for blockchain communication
  # Calls OSC-API (PHP) on OSC-DEV2 via HTTPS Bearer token
  # Adapter — calls OSC-API (PHP) on OSC-DEV2 via HTTPS Bearer token
  # ADAPTER_API_URL and ADAPTER_API_TOKEN are stored in Secrets Manager (not plain env vars)
  "osc-adapter" = {
    task_def_template_path = "${path.module}/../task-defs/adapter.json.tmpl"
    task_def_vars = {
      cpu                             = "256"
      memory                          = "512"
      execution_role_arn              = "<execution-role-arn>"
      task_role_arn                   = "<task-role-arn>"
      image                           = "<ecr-image-uri>"
      adapter_port                    = "5000"
      adapter_request_timeout_seconds = "30"
      adapter_api_url_secret_arn      = "<secret-arn>"   # /osc/<env>/adapter/api-url
      adapter_api_token_secret_arn    = "<secret-arn>"   # /osc/<env>/adapter/api-token
      log_group                       = "/ecs/osc-adapter"
      aws_region                      = "us-west-2"
    }
    desired_count = 1
  }

  # Submission Worker — consumes artifact.submit / artifact.update from RabbitMQ
  "osc-submission-worker" = {
    task_def_template_path = "${path.module}/../task-defs/submission-worker.json.tmpl"
    task_def_vars = {
      cpu                        = "512"
      memory                     = "1024"
      execution_role_arn         = "<execution-role-arn>"
      task_role_arn              = "<task-role-arn>"
      image                      = "<ecr-image-uri>"
      rabbitmq_queue_submit      = "artifact.submit.queue"
      rabbitmq_queue_submitted   = "artifact.submitted.queue"
      rabbitmq_queue_update      = "artifact.update.queue"
      rabbitmq_queue_updated     = "artifact.updated.queue"
      rabbitmq_port              = "5672"
      rabbitmq_host              = "<rabbitmq-nlb-dns>"
      fabric_bridge_url          = "http://osc-adapter:5000"     # Points to adapter, not fabric-bridge
      environment                = "aws"
      rabbitmq_user_secret_arn   = "<secret-arn>"
      rabbitmq_pass_secret_arn   = "<secret-arn>"
      log_group                  = "/ecs/osc-submission-worker"
      aws_region                 = "us-west-2"
    }
    desired_count = 1
  }

  # Submission Listener — consumes results and PATCHes API Gateway
  "osc-submission-listener" = {
    task_def_template_path = "${path.module}/../task-defs/submission-listener.json.tmpl"
    task_def_vars = {
      cpu                                           = "256"
      memory                                        = "512"
      execution_role_arn                            = "<execution-role-arn>"
      task_role_arn                                 = "<task-role-arn>"
      image                                         = "<ecr-image-uri>"
      rabbitmq_host                                 = "<rabbitmq-nlb-dns>"
      rabbitmq_port                                 = "5672"
      rabbitmq_queue_submitted                      = "artifact.submitted.queue"
      rabbitmq_queue_updated                        = "artifact.updated.queue"
      api_gateway_url                               = "http://osc-api-blue:3000/api/v1/artifacts"
      environment                                   = "aws"
      rabbitmq_user_secret_arn                      = "<secret-arn>"
      rabbitmq_pass_secret_arn                      = "<secret-arn>"
      submission_listener_api_key_secret_arn        = "<secret-arn>"
      submission_listener_service_role_secret_arn   = "<secret-arn>"
      log_group                                     = "/ecs/osc-submission-listener"
      aws_region                                    = "us-west-2"
    }
    desired_count = 1
  }

  # Get History Worker — proxies history requests to adapter
  "osc-get-history-worker" = {
    task_def_template_path = "${path.module}/../task-defs/get-history-worker.json.tmpl"
    task_def_vars = {
      cpu                 = "256"
      memory              = "512"
      execution_role_arn  = "<execution-role-arn>"
      task_role_arn       = "<task-role-arn>"
      image               = "<ecr-image-uri>"
      bridge_url          = "http://osc-adapter:5000"            # Points to adapter, not fabric-bridge
      cache_ttl_seconds   = "300"
      cache_max_artifacts = "200"
      max_page_size       = "500"
      log_group           = "/ecs/osc-get-history-worker"
      aws_region          = "us-west-2"
    }
    desired_count = 1
  }
}

# --------------------
# Hybrid infra hibernation
# Set manage_hybrid_infra=true once ALB/NLB/NAT/RDS are imported into state.
# Use `make down-hybrid` to destroy expensive resources and reach ~$0/day.
# Use `make up-hybrid` to restore from RDS snapshot and recreate all resources.
# --------------------
manage_hybrid_infra = true
infra_mode          = "active"   # active | hibernated
allow_destroy       = false      # must be true for infra_mode=hibernated

alb = {
  name                       = "osc-staging-alb"
  internal                   = false
  security_group_ids         = ["<alb-sg-id>"]
  subnet_ids                 = ["<public-subnet-2a>", "<public-subnet-2b>"]
  idle_timeout               = 60
  enable_deletion_protection = false
  listener_port              = 443
  listener_protocol          = "HTTPS"
  certificate_arn            = "<acm-certificate-arn>"
  target_group = {
    name              = "osc-api-blue-2-tg"
    port              = 3000
    protocol          = "HTTP"
    target_type       = "ip"
    health_check_path = "/api/v1/health"
  }
  route53_record_name = "<api.your-domain.com>"
  route53_zone_id     = "<hosted-zone-id>"
}

nlb = {
  name          = "osc-rabbitmq-nlb"
  internal      = true
  subnet_ids    = ["<private-subnet-2a>", "<private-subnet-2b>"]
  listener_port     = 5672
  listener_protocol = "TCP"
  target_group = {
    name        = "osc-rabbitmq-tg"
    port        = 5672
    protocol    = "TCP"
    target_type = "ip"
  }
}

nat = {
  subnet_id               = "<public-subnet-2a>"
  private_route_table_ids = ["<private-rtb-2a>", "<private-rtb-2b>"]
  create_eip              = true
}

rds = {
  identifier                      = "oscdb"
  instance_class                  = "db.t4g.micro"
  db_subnet_ids                   = ["<private-subnet-2a>", "<private-subnet-2b>"]
  vpc_security_group_ids          = ["<rds-sg-id>"]
  publicly_accessible             = false
  multi_az                        = false
  deletion_protection             = false
  restore_from_latest_snapshot    = true
  final_snapshot_identifier       = "oscdb-hibernate-snapshot"
}
